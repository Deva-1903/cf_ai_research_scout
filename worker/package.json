{
  "name": "cf-ai-research-scout-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute cf-ai-research-scout-db --local --file=schema.sql",
    "db:init:remote": "wrangler d1 execute cf-ai-research-scout-db --remote --file=schema.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "latest",
    "agents": "latest",
    "ai": "latest",
    "hono": "^4.6.3",
    "workers-ai-provider": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^5.6.3",
    "wrangler": "^4.77.0"
  }
}
